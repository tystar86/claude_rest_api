SECRET_KEY=replace-with-a-strong-random-secret-key
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com

DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=replace-with-your-production-db-password
DB_HOST=replace-with-your-production-db-host
DB_PORT=5432
DB_CONN_MAX_AGE=60

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
CSRF_TRUSTED_ORIGINS=https://your-frontend.example.com
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None

GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

DRF_THROTTLE_LOGIN=5/min
ACCOUNT_EMAIL_VERIFICATION=mandatory
FEATURE_EMAIL_VERIFICATION_ROLLOUT=true
EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
MAILGUN_API_KEY=replace-with-your-mailgun-api-key
MAILGUN_DOMAIN=replace-with-your-mailgun-domain
